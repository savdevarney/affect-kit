      <a href="https://github.com/savdevarney/affect-kit">github.com/savdevarney/affect-kit</a>
    </p>
  </footer>

  <script>
    import 'affect-kit/rater';
    import 'affect-kit/result';
    import 'affect-kit/face';
    import 'affect-kit/compare';
    import { createRating } from 'affect-kit';
    import type { ColorMode } from 'affect-kit';
    import type { AffectKitRater }   from 'affect-kit/rater';
    import type { AffectKitResult }  from 'affect-kit/result';
    import type { AffectKitFace }    from 'affect-kit/face';
    import type { AffectKitCompare } from 'affect-kit/compare';

    // ── Control helpers ────────────────────────────────────────────────
    function toggle(id: string, on: (next: boolean) => void) {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      btn?.addEventListener('click', () => {
        const next = btn.getAttribute('aria-pressed') !== 'true';
        btn.setAttribute('aria-pressed', String(next));
        on(next);
      });
    }
    function seg(name: string, on: (value: ColorMode | null) => void) {
      const group = document.querySelector<HTMLElement>(`[data-seg="${name}"]`);
      const btns  = group ? [...group.querySelectorAll<HTMLButtonElement>('.docs-seg-btn')] : [];
      btns.forEach(b => {
        b.addEventListener('click', () => {
          const value = b.dataset.val ?? 'off';
          if (group) group.dataset.value = value;
          btns.forEach(o => o.setAttribute('aria-pressed', String(o === b)));
          on(value === 'background' ? 'background' : value === 'words' ? 'words' : null);
        });
      });
    }

    // ── Rater ─────────────────────────────────────────────────────────
    const rater  = document.getElementById('docs-rater')  as AffectKitRater  | null;
    const result = document.getElementById('docs-result') as AffectKitResult | null;
    rater?.addEventListener('change', (e) => {
      if (result) result.rating = (e as CustomEvent).detail;
    });
    seg('docs-rater-color',          (m) => { if (rater) rater.colorMode = m; });
    toggle('docs-rater-animated',    (v) => { if (rater) rater.animated  = v; });

    // ── Result pre-seed + controls ────────────────────────────────────
    const seed = createRating({ face: { v: 0.55, a: 0.2 }, labels: [
      { name: 'content',  level: 3 },
      { name: 'grateful', level: 2 },
      { name: 'calm',     level: 1 },
    ]});
    if (result) result.rating = seed;
    seg('docs-result-color',         (m) => { if (result) result.colorMode  = m; });
    toggle('docs-result-face',       (v) => { if (result) result.showFace   = v; });
    toggle('docs-result-labels',     (v) => { if (result) result.showLabels = v; });
    (document.getElementById('docs-result-align')   as HTMLSelectElement | null)
      ?.addEventListener('change', (e) => { if (result) result.align   = (e.target as HTMLSelectElement).value as 'left' | 'center' | 'right'; });
    (document.getElementById('docs-result-variant') as HTMLSelectElement | null)
      ?.addEventListener('change', (e) => { if (result) result.variant = (e.target as HTMLSelectElement).value as 'default' | 'compact'; });

    // ── Face sliders ──────────────────────────────────────────────────
    const face    = document.getElementById('docs-face')     as AffectKitFace  | null;
    const vSlider = document.getElementById('docs-v-slider') as HTMLInputElement | null;
    const aSlider = document.getElementById('docs-a-slider') as HTMLInputElement | null;
    const vVal    = document.getElementById('docs-v-val');
    const aVal    = document.getElementById('docs-a-val');

    function updateFace() {
      if (!face || !vSlider || !aSlider) return;
      const v = parseFloat(vSlider.value);
      const a = parseFloat(aSlider.value);
      face.v = v; face.a = a;
      if (vVal) vVal.textContent = v.toFixed(2);
      if (aVal) aVal.textContent = a.toFixed(2);
    }
    vSlider?.addEventListener('input', updateFace);
    aSlider?.addEventListener('input', updateFace);

    // ── Compare pre-seed + controls ───────────────────────────────────
    const before = [
      createRating({ face: { v: -0.5, a: 0.5 }, labels: [{ name: 'overwhelmed', level: 3 }, { name: 'anxious', level: 2 }] }),
      createRating({ face: { v: -0.4, a: 0.4 }, labels: [{ name: 'frustrated', level: 2 }, { name: 'tired', level: 2 }] }),
    ];
    const after = [
      createRating({ face: { v:  0.6, a: 0.3 }, labels: [{ name: 'calm', level: 2 }, { name: 'hopeful', level: 2 }] }),
      createRating({ face: { v:  0.7, a: 0.4 }, labels: [{ name: 'joy', level: 3 }, { name: 'grateful', level: 1 }] }),
    ];
    const cmp = document.getElementById('docs-compare') as AffectKitCompare | null;
    if (cmp) { cmp.beforeRating = before; cmp.afterRating = after; }
    seg('docs-compare-color',        (m) => { if (cmp) cmp.colorMode  = m; });
    toggle('docs-compare-face',      (v) => { if (cmp) cmp.showFace   = v; });
    toggle('docs-compare-labels',    (v) => { if (cmp) cmp.showLabels = v; });
  </script>

</Base>

