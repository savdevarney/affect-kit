  <div class="rp-layout">

    <!-- ── Sidebar ToC ──────────────────────────────────────── -->
    <aside class="rp-toc">
      <nav>
        <ol class="rp-toc-list">
          <li><a href="#getting-started">Getting started</a></li>
          <li><a href="#rater">&lt;affect-kit-rater&gt;</a></li>
          <li><a href="#result">&lt;affect-kit-result&gt;</a></li>
          <li><a href="#face">&lt;affect-kit-face&gt;</a></li>
          <li><a href="#compare">&lt;affect-kit-compare&gt;</a></li>
          <li><a href="#types">TypeScript types</a></li>
        </ol>
      </nav>
    </aside>

    <!-- ── Main content ────────────────────────────────────── -->
    <main class="rp-content">

      <header class="rp-header">
        <p class="section-eyebrow">Component reference</p>
        <h1 class="rp-title">Components</h1>
        <p class="rp-lead">
          Four web components — custom elements built with Lit, framework-agnostic,
          TypeScript-first. Each component has a named entry point for precise imports.
          The <code>Rating</code> object is the shared data contract between them.
        </p>
      </header>

      <!-- ── 1: Getting started ─────────────────────────── -->
      <section id="getting-started" class="rp-section">
        <h2>Getting started</h2>

        <pre class="docs-code">npm install affect-kit</pre>

        <h3>Imports</h3>
        <p>Each component has its own entry point. Import only what you need:</p>
        <pre class="docs-code">import 'affect-kit/rater';   // registers &lt;affect-kit-rater&gt;
import 'affect-kit/result';  // registers &lt;affect-kit-result&gt;
import 'affect-kit/face';    // registers &lt;affect-kit-face&gt;
import 'affect-kit/compare'; // registers &lt;affect-kit-compare&gt;

// Or register all four at once:
import 'affect-kit';</pre>

        <h3>TypeScript types</h3>
        <pre class="docs-code" set:text={`import type { Rating, EmotionLabel, EmotionName } from 'affect-kit';
import { createRating, averageRatings }           from 'affect-kit';`}></pre>

        <h3>Quick wiring: rater → result</h3>
        <pre class="docs-code">&lt;affect-kit-rater id="rater"&gt;&lt;/affect-kit-rater&gt;
&lt;affect-kit-result id="result" show-face show-labels color-mode&gt;&lt;/affect-kit-result&gt;

&lt;script type="module"&gt;
  import 'affect-kit/rater';
  import 'affect-kit/result';

  const rater  = document.querySelector('affect-kit-rater');
  const result = document.querySelector('affect-kit-result');
  rater.addEventListener('change', e =&gt; result.rating = e.detail);
&lt;/script&gt;</pre>

        <h3>React</h3>
        <p>
          Custom elements work in React 19+ with native support, or React 18 with a thin ref wrapper.
          TypeScript types are available via the global <code>HTMLElementTagNameMap</code> augmentation
          shipped in each component entry point.
        </p>
        <pre class="docs-code" set:text={`// React 19+
import 'affect-kit/rater';

function App() {
  return (
    <affect-kit-rater
      color-mode
      onchange={(e) => console.log(e.detail)}
    />
  );
}`}></pre>
      </section>

      <!-- ── 2: affect-kit-rater ────────────────────────── -->
      <section id="rater" class="rp-section">
        <h2>2. <code>&lt;affect-kit-rater&gt;</code></h2>
        <p>
          The primary capture interface. The user drags on a V/A pad to set a gut-feeling position —
          the face glyph and background color update in real time. On release, 55 emotion chips
          from the NRC VAD Lexicon rearrange by proximity to the pad position. The user taps chips
          to intensity-rate them at 1, 2, or 3. Every pad release and chip toggle after the first
          placement fires a <code>change</code> event with a <code>Rating</code> object.
        </p>

        <div class="docs-demo">
          <affect-kit-rater id="docs-rater" show-vad color-mode></affect-kit-rater>
        </div>

        <h3>Attributes / props</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Attribute</th><th>Type</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>color-mode</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Tints the surface with the current V/A quadrant color. Chips automatically adapt their contrast to the surface lightness.</td>
              </tr>
              <tr>
                <td><code>animated</code></td>
                <td>boolean</td>
                <td><code>true</code></td>
                <td>Enables breath + tremor animation on the face glyph. Always respects <code>prefers-reduced-motion: reduce</code>. Set <code>animated="false"</code> in HTML to opt out.</td>
              </tr>
              <tr>
                <td><code>show-vad</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Shows a debug readout of the current V / A / D values below the chip list.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Events</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Event</th><th>Detail type</th><th>When it fires</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>change</code></td>
                <td><code>Rating</code></td>
                <td>On every pointer release from the pad, and on every chip toggle after the first pad placement. Not fired on the initial drag before first release.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Methods</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Method</th><th>Signature</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>setRating()</code></td>
                <td><code>(rating: Rating) =&gt; void</code></td>
                <td>Programmatically pre-fills the rater from a <code>Rating</code> object. Reveals chips immediately. Useful for editing a previously captured rating.</td>
              </tr>
              <tr>
                <td><code>reset()</code></td>
                <td><code>() =&gt; void</code></td>
                <td>Clears all state back to the initial empty position — pad at center, no chips selected, face neutral.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>CSS custom properties</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Property</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>--affect-kit-rater-max-width</code></td>
                <td><code>640px</code></td>
                <td>Maximum width of the widget. Override to fit narrow or wide containers.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- ── 3: affect-kit-result ───────────────────────── -->
      <section id="result" class="rp-section">
        <h2>3. <code>&lt;affect-kit-result&gt;</code></h2>
        <p>
          A display panel for a captured <code>Rating</code>. Renders the selected emotion words
          scaled by intensity (level 3 is largest, level 1 is smallest), an optional face glyph,
          and an optional color tint. Designed to pair with <code>&lt;affect-kit-rater&gt;</code>
          but can also be driven from stored data. The face and color always follow
          <code>rating.pad</code> (the raw drag position), not the label-aggregated coordinates —
          preserving the visual signal of the gut feeling even when labels shift the V/A/D values.
        </p>

        <div class="docs-demo">
          <affect-kit-result id="docs-result" show-face show-labels color-mode></affect-kit-result>
          <p class="docs-demo-hint">← Rate something on the rater above to see it here, or this is pre-seeded.</p>
        </div>

        <h3>Attributes / props</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Attribute / prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>rating</code> <span class="docs-prop-tag">prop only</span></td>
                <td><code>Rating | null</code></td>
                <td><code>null</code></td>
                <td>The rating to display. Set via JavaScript property — not an HTML attribute. The component renders nothing when <code>null</code>.</td>
              </tr>
              <tr>
                <td><code>show-face</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Show the face glyph. Face shape and color follow <code>rating.pad</code>, not the label-aggregated V/A.</td>
              </tr>
              <tr>
                <td><code>show-labels</code></td>
                <td>boolean</td>
                <td><code>true</code></td>
                <td>Show the selected emotion words, scaled continuously by intensity level.</td>
              </tr>
              <tr>
                <td><code>color-mode</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Apply a V/A color tint to the panel background.</td>
              </tr>
              <tr>
                <td><code>show-vad</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Show the raw V / A / D readout (debug).</td>
              </tr>
              <tr>
                <td><code>align</code></td>
                <td><code>'left' | 'center' | 'right'</code></td>
                <td><code>'center'</code></td>
                <td>Word alignment within the panel.</td>
              </tr>
              <tr>
                <td><code>variant</code></td>
                <td><code>'default' | 'compact'</code></td>
                <td><code>'default'</code></td>
                <td>Sizing preset. <code>'compact'</code> reduces padding for tight layouts.</td>
              </tr>
              <tr>
                <td><code>bare</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Strips the panel chrome (background, padding, shadow, radius) and color glow. Use when embedding inside a parent that manages its own card, e.g. <code>&lt;affect-kit-compare&gt;</code>.</td>
              </tr>
              <tr>
                <td><code>mirror</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Flips the face / words order. In row mode → face right, words left. In column mode → face below words. Useful in paired layouts.</td>
              </tr>
              <tr>
                <td><code>animated</code></td>
                <td>boolean</td>
                <td><code>true</code></td>
                <td>Enables breath animation on the face glyph. Respects <code>prefers-reduced-motion</code>.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>CSS custom properties</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Property</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>--affect-kit-result-max-width</code></td>
                <td><code>640px</code></td>
                <td>Maximum width of the widget.</td>
              </tr>
              <tr>
                <td><code>--affect-kit-font-display</code></td>
                <td><code>'DM Serif Display', Georgia, serif</code></td>
                <td>Display serif used for high-intensity emotion words (level ≥ 2.5).</td>
              </tr>
              <tr>
                <td><code>--affect-kit-ink</code></td>
                <td><code>#1a1a1a</code></td>
                <td>Ink color for emotion words.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Layout custom properties</h3>
        <p>
          These pierce the shadow DOM and let a parent container (like
          <code>&lt;affect-kit-compare&gt;</code>) drive the inner face/words layout via
          container queries without JS:
        </p>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Property</th><th>Controls</th></tr>
            </thead>
            <tbody>
              <tr><td><code>--_face-dir</code></td><td><code>flex-direction</code> of the content row</td></tr>
              <tr><td><code>--_face-align</code></td><td><code>align-items</code> of the content row</td></tr>
              <tr><td><code>--_face-gap</code></td><td>Gap between face and words</td></tr>
              <tr><td><code>--_face-step</code></td><td>Word size growth per intensity level</td></tr>
              <tr><td><code>--_face-mb</code></td><td>Face zone <code>margin-bottom</code></td></tr>
              <tr><td><code>--_face-mt</code></td><td>Face zone <code>margin-top</code></td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- ── 4: affect-kit-face ─────────────────────────── -->
      <section id="face" class="rp-section">
        <h2>4. <code>&lt;affect-kit-face&gt;</code></h2>
        <p>
          A standalone animated face glyph driven directly by <code>v</code> (valence) and
          <code>a</code> (arousal) props. Runs a 60 fps animation loop by default — breath
          (subtle scale oscillation) and tremor (position noise scaled by arousal). Size is
          set via CSS; the SVG fills its container. Used internally by both
          <code>&lt;affect-kit-rater&gt;</code> and <code>&lt;affect-kit-result&gt;</code>.
        </p>

        <div class="docs-demo docs-face-demo">
          <affect-kit-face id="docs-face" v="0" a="0" style="width:140px;height:140px"></affect-kit-face>
          <div class="docs-face-sliders">
            <div class="slider-row">
              <label for="docs-v-slider">V</label>
              <input type="range" id="docs-v-slider" min="-1" max="1" step="0.01" value="0">
              <span class="slider-val" id="docs-v-val">0.00</span>
            </div>
            <div class="slider-row">
              <label for="docs-a-slider">A</label>
              <input type="range" id="docs-a-slider" min="-1" max="1" step="0.01" value="0">
              <span class="slider-val" id="docs-a-val">0.00</span>
            </div>
          </div>
        </div>

        <h3>Attributes / props</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Attribute / prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>v</code></td>
                <td>number</td>
                <td><code>0</code></td>
                <td>Valence ∈ [−1, 1]. Drives brow angle, eye shape, and mouth curve. Clamped silently if out of range.</td>
              </tr>
              <tr>
                <td><code>a</code></td>
                <td>number</td>
                <td><code>0</code></td>
                <td>Arousal ∈ [−1, 1]. Drives eye openness, animation tremor amplitude, and lip parting. Clamped silently.</td>
              </tr>
              <tr>
                <td><code>animated</code></td>
                <td>boolean</td>
                <td><code>true</code></td>
                <td>Enables breath + tremor animation. Use <code>animated="false"</code> in HTML. Always respects <code>prefers-reduced-motion: reduce</code> regardless of this attribute.</td>
              </tr>
              <tr>
                <td><code>motionScale</code> <span class="docs-prop-tag">prop only</span></td>
                <td>number</td>
                <td><code>1</code></td>
                <td>Scales all animation amplitude in [0, 1]. The rater sets this to ~0.2 while the user is actively dragging so the face stays readable, then restores to 1.0 on release.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Methods</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Method</th><th>Signature</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>triggerShock()</code></td>
                <td><code>() =&gt; void</code></td>
                <td>Triggers a brief high-frequency shake. Called by <code>&lt;affect-kit-rater&gt;</code> internally when a high-arousal emotion chip is toggled up, so the face reacts to the selection.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Default size</h3>
        <p>
          The element defaults to <code>120 × 120px</code> (set via <code>:host</code> styles).
          Override freely with CSS — the SVG fills 100% of its container:
        </p>
        <pre class="docs-code" set:text={`affect-kit-face { width: 80px; height: 80px; }
/* or inline: */
<affect-kit-face style="width:200px;height:200px"></affect-kit-face>`}></pre>
      </section>

      <!-- ── 5: affect-kit-compare ──────────────────────── -->
      <section id="compare" class="rp-section">
        <h2>5. <code>&lt;affect-kit-compare&gt;</code></h2>
        <p>
          A paired side-by-side display for two ratings or two rating arrays. When
          <code>color-mode</code> is on, the card background is a gradient from the
          left rating's V/A color to the right rating's V/A color — the color transition
          itself tells the story. Layout responds to host width via container queries:
          side-by-side when wide, stacked when narrow. Each half's face sits on the outer
          edge so the faces frame the gradient. The widget makes no claims about what the
          comparison means — interpretation belongs to the user.
        </p>

        <div class="docs-demo">
          <affect-kit-compare
            id="docs-compare"
            show-face
            color-mode
            show-labels
            before-label="Last week"
            after-label="This week"
          ></affect-kit-compare>
        </div>

        <h3>Attributes / props</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Attribute / prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>beforeRating</code> <span class="docs-prop-tag">prop only</span></td>
                <td><code>Rating | Rating[] | null</code></td>
                <td><code>null</code></td>
                <td>Left side. A single <code>Rating</code> (rendered as-is) or a <code>Rating[]</code> (averaged via <code>averageRatings()</code>). Property is <code>beforeRating</code> because <code>before</code> is reserved on <code>Element</code>.</td>
              </tr>
              <tr>
                <td><code>afterRating</code> <span class="docs-prop-tag">prop only</span></td>
                <td><code>Rating | Rating[] | null</code></td>
                <td><code>null</code></td>
                <td>Right side. Same shape as <code>beforeRating</code>.</td>
              </tr>
              <tr>
                <td><code>before-label</code></td>
                <td>string</td>
                <td><code>'Before'</code></td>
                <td>Caption above the left rating.</td>
              </tr>
              <tr>
                <td><code>after-label</code></td>
                <td>string</td>
                <td><code>'After'</code></td>
                <td>Caption above the right rating.</td>
              </tr>
              <tr>
                <td><code>show-face</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>Show face glyphs in each half. Forwarded to each inner <code>&lt;affect-kit-result&gt;</code>.</td>
              </tr>
              <tr>
                <td><code>show-labels</code></td>
                <td>boolean</td>
                <td><code>true</code></td>
                <td>Show emotion words in each half.</td>
              </tr>
              <tr>
                <td><code>color-mode</code></td>
                <td>boolean</td>
                <td><code>false</code></td>
                <td>When on, the card background is a gradient between the two V/A colors.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>CSS custom properties</h3>
        <div class="docs-table-wrap">
          <table class="docs-table">
            <thead>
              <tr><th>Property</th><th>Default</th><th>Description</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>--affect-kit-compare-max-width</code></td>
                <td><code>880px</code></td>
                <td>Maximum width of the widget.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Averaging arrays</h3>
        <p>
          Pass a <code>Rating[]</code> to either side and the widget averages it automatically.
          Useful for windowed comparisons (e.g. last month vs last week):
        </p>
        <pre class="docs-code" set:text={`import 'affect-kit/compare';
import { createRating } from 'affect-kit';

const cmp = document.querySelector('affect-kit-compare');
cmp.beforeRating = lastMonthRatings; // Rating[]
cmp.afterRating  = lastWeekRatings;  // Rating[]`}></pre>
      </section>

      <!-- ── 6: TypeScript types ────────────────────────── -->
      <section id="types" class="rp-section">
        <h2>6. TypeScript types</h2>
        <pre class="docs-code" set:text={`import type { Rating, EmotionLabel, EmotionName } from 'affect-kit';
import { createRating, averageRatings }           from 'affect-kit';`}></pre>

        <h3>Rating</h3>
        <p>The central data object. Emitted by <code>change</code> events, consumed by result and compare.</p>
        <pre class="docs-code" set:text={`interface Rating {
  /** Valence ∈ [-1, 1]. Drives face shape and color. */
  v: number;
  /** Arousal ∈ [-1, 1]. Drives face shape and color. */
  a: number;
  /** Dominance ∈ [-1, 1]. Not visualized — preserved as analytical metadata. */
  d: number;
  /** Raw pad position before label aggregation. */
  pad: { v: number; a: number };
  /** True when v/a were aggregated from labels rather than from the pad drag. */
  fromLabels: boolean;
  /** Selected emotion words and their intensity. */
  labels: EmotionLabel[];
  /** Unix timestamp (ms) at commit time. */
  timestamp: number;
}`}></pre>

        <h3>EmotionLabel</h3>
        <pre class="docs-code" set:text={`interface EmotionLabel {
  name: string;  // must be a valid EmotionName from the NRC vocabulary
  level: number; // 1 | 2 | 3 from rater; widened to number for averaged data
}`}></pre>

        <h3>createRating()</h3>
        <p>Construct a <code>Rating</code> from a pad position and optional labels. Useful for seeding demos and tests:</p>
        <pre class="docs-code" set:text={`import { createRating } from 'affect-kit';

const r = createRating({
  v: 0.5, a: 0.3,           // pad position (required)
  labels: [                  // optional
    { name: 'calm',     level: 2 },
    { name: 'grateful', level: 1 },
  ],
});`}></pre>

        <h3>averageRatings()</h3>
        <p>Average an array of <code>Rating</code> objects into a single <code>Rating</code>. Label levels are averaged continuously — the result widget renders averaged levels as continuous intermediate sizes:</p>
        <pre class="docs-code" set:text={`import { averageRatings } from 'affect-kit';

const avg = averageRatings(sessionRatings); // Rating[] → Rating`}></pre>
      </section>

