---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---
<Base title="affect-kit — Capture feeling. Track it over time.">

  <nav class="site-nav">
    <a href="/" class="wordmark">affect-kit</a>
    <div class="nav-links">
      <a href="/research">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.5 2a.5.5 0 0 0-.5.5V8L4.146 14.16A2 2 0 0 0 5.9 17h8.2a2 2 0 0 0 1.754-2.84L12 8V2.5a.5.5 0 0 0-.5-.5h-3Zm-1 .5V8.5a.5.5 0 0 1-.072.258L5.062 12h9.876l-2.366-3.242A.5.5 0 0 1 12.5 8.5V2.5h-5Z" clip-rule="evenodd"/>
        </svg>
        Research
      </a>
      <a href="/docs">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z"/>
        </svg>
        Docs
      </a>
      <a href="https://github.com/savdevarney/affect-kit" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
      <a href="https://www.npmjs.com/package/affect-kit" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M4 4h16v12H12v2H8v-2H4V4Zm2 2v8h4v-6h2v6h2V6H6Z"/>
        </svg>
        npm
      </a>
    </div>
  </nav>

  <main>

    <!-- ── Hero ──────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <h1>Capture feeling. Track it over time.</h1>
          <p class="hero-tagline">
            Open-source web components grounded in affective science.
            Framework-agnostic. MIT licensed.
          </p>
          <div class="install-chip">npm install affect-kit</div>
        </div>

        <div class="hero-demo">
          <div class="hero-demo-slot" id="hero-demo-slot">
            <div class="hero-demo-pane" id="hero-rater-pane">
              <p class="demo-label">&lt;affect-kit-rater&gt;</p>
              <affect-kit-rater id="hero-rater" color-mode></affect-kit-rater>
            </div>
            <div class="hero-demo-pane hero-demo-pane--result" id="hero-result-pane">
              <p class="demo-label">&lt;affect-kit-result&gt;</p>
              <affect-kit-result id="hero-result" show-face show-labels color-mode></affect-kit-result>
              <details class="hero-json-wrap">
                <summary class="demo-label">commit event.detail</summary>
                <pre class="hero-rating-json"><code id="hero-rating-json"></code></pre>
              </details>
              <button class="hero-rerate" id="hero-rerate">← rate again</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Code snippet ───────────────────────────────────────── -->
    <section class="snippet-section">
      <div class="snippet-inner">
        <pre class="code-block"><code>import 'affect-kit/rater';
import 'affect-kit/result';

// In your HTML:
// &lt;affect-kit-rater&gt;&lt;/affect-kit-rater&gt;
// &lt;affect-kit-result show-face show-labels color-mode&gt;&lt;/affect-kit-result&gt;

const rater = document.querySelector('affect-kit-rater');
const result = document.querySelector('affect-kit-result');
rater.addEventListener('change', (e) =&gt; result.rating = e.detail);</code></pre>
      </div>
    </section>

    <!-- ── Pillars ────────────────────────────────────────────── -->
    <section class="pillars">
      <div class="pillar">
        <span class="pillar-accent" style="background: var(--color-blue)"></span>
        <h3>Web-standard</h3>
        <p>Built with Lit. Custom elements that work in React, Vue, Angular, SvelteKit, or plain HTML — no framework required.</p>
      </div>
      <div class="pillar">
        <span class="pillar-accent" style="background: var(--color-gold)"></span>
        <h3>Science-grounded</h3>
        <p>Valence × arousal × dominance from the NRC VAD Lexicon. Minimal FACS face glyph — no skin tone, no gender encoding.</p>
      </div>
      <div class="pillar">
        <span class="pillar-accent" style="background: var(--color-green)"></span>
        <h3>Logbook-faithful</h3>
        <p>A substrate for capturing and rendering emotion ratings — not a diagnostic tool. No interpretation, no "wellness scores."</p>
      </div>
    </section>

    <!-- ── Face spectrum ──────────────────────────────────────── -->
    <section class="face-spectrum">
      <div class="face-spectrum-inner">
      <p class="section-eyebrow">The face glyph</p>
      <h2 class="section-heading">One continuous face, not categories</h2>
      <p class="section-note">
        Driven by valence (positive ↔ negative) and arousal (energized ↔ calm).
        Based on FACS action units cross-culturally validated in 17 cultures.
      </p>
      <div class="face-row">
        <div class="face-item">
          <affect-kit-face v="-0.8" a="0.8"></affect-kit-face>
          <span class="face-word">anger</span>
          <span class="face-coords">v=−0.8, a=0.8</span>
        </div>
        <div class="face-item">
          <affect-kit-face v="-0.4" a="0.5"></affect-kit-face>
          <span class="face-word">anxious</span>
          <span class="face-coords">v=−0.4, a=0.5</span>
        </div>
        <div class="face-item">
          <affect-kit-face v="0" a="0"></affect-kit-face>
          <span class="face-word">neutral</span>
          <span class="face-coords">v=0, a=0</span>
        </div>
        <div class="face-item">
          <affect-kit-face v="0.6" a="-0.5"></affect-kit-face>
          <span class="face-word">content</span>
          <span class="face-coords">v=0.6, a=−0.5</span>
        </div>
        <div class="face-item">
          <affect-kit-face v="0.8" a="0.8"></affect-kit-face>
          <span class="face-word">joy</span>
          <span class="face-coords">v=0.8, a=0.8</span>
        </div>
      </div>
      </div><!-- /face-spectrum-inner -->
    </section>

    <!-- ── Components ─────────────────────────────────────────── -->
    <section class="components">
      <div class="components-inner">
        <h2 class="section-heading">Four components</h2>

        <div class="component-grid">

          <!-- affect-kit-compare: wide card, live demo -->
          <div class="component-card component-card--wide component-card--centered">
            <p class="component-tag">&lt;affect-kit-compare&gt;</p>
            <p class="component-desc">
              Two snapshots side-by-side — or two arrays of ratings averaged.
              Same face + word + color vocabulary as <code>&lt;affect-kit-result&gt;</code>.
              No comparison metric, no "improvement" claim.
            </p>
            <affect-kit-compare
              id="site-compare"
              show-face
              color-mode
              show-labels
              before-label="Yesterday"
              after-label="Today"
            ></affect-kit-compare>
            <a href="/docs#compare" class="component-link">Docs →</a>
          </div>

          <!-- affect-kit-rater -->
          <div class="component-card">
            <p class="component-tag">&lt;affect-kit-rater&gt;</p>
            <p class="component-desc">
              The primary input. Drag on the V/A pad to set a gut-feeling position,
              then intensity-rate up to 5 labels from the NRC VAD lexicon. Fires a
              <code>change</code> event on commit.
            </p>
            <a href="/docs#rater" class="component-link">Docs →</a>
          </div>

          <!-- affect-kit-result -->
          <div class="component-card">
            <p class="component-tag">&lt;affect-kit-result&gt;</p>
            <p class="component-desc">
              Renders a committed <code>Rating</code> as a face glyph, dominant label word,
              and optional color chip. Pair with <code>&lt;affect-kit-rater&gt;</code>
              or drive from stored data.
            </p>
            <a href="/docs#result" class="component-link">Docs →</a>
          </div>

          <!-- affect-kit-face -->
          <div class="component-card">
            <p class="component-tag">&lt;affect-kit-face&gt;</p>
            <p class="component-desc">
              Standalone face glyph driven by <code>v</code> and <code>a</code> props.
              Any size via CSS. Animates breath + tremor by default.
            </p>
            <a href="/docs#face" class="component-link">Docs →</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Research ───────────────────────────────────────────── -->
    <section class="research">
      <div class="research-inner">
        <p class="section-eyebrow">Scientific foundations</p>
        <h2 class="section-heading">Feeling first, naming second</h2>
        <p>
          The dimensional model treats affect as continuous — valence and arousal carry
          cross-cultural neural signatures more robust than discrete categories like
          "happiness" or "fear." The V/A pad captures the gut signal first; labels refine
          it second. Dominance — the sense of agency — is preserved in every
          <code>Rating</code>, distinguishing <em>frustrated</em> from <em>anxious</em>
          even when their V/A coordinates look identical.
        </p>
        <a href="/research" class="research-link">Explore the research foundations →</a>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────── -->
    <section class="cta">
      <h2>Get started</h2>
      <div class="cta-row">
        <span class="cta-chip">npm install affect-kit</span>
        <a href="https://github.com/savdevarney/affect-kit" class="cta-link">
          View on GitHub →
        </a>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <p>
      affect-kit · MIT License ·
      <a href="https://github.com/savdevarney/affect-kit">github.com/savdevarney/affect-kit</a>
    </p>
  </footer>

  <script>
    import 'affect-kit/rater';
    import 'affect-kit/result';
    import 'affect-kit/face';
    import 'affect-kit/compare';
    import { createRating } from 'affect-kit';
    import type { AffectKitRater }   from 'affect-kit/rater';
    import type { AffectKitResult }  from 'affect-kit/result';
    import type { AffectKitCompare } from 'affect-kit/compare';

    // ── Hero: rater commits → result replaces it; rerate → back ──
    const rater     = document.getElementById('hero-rater')     as AffectKitRater  | null;
    const result    = document.getElementById('hero-result')    as AffectKitResult | null;
    const slot      = document.getElementById('hero-demo-slot');
    const raterPane = document.getElementById('hero-rater-pane');
    const rerate    = document.getElementById('hero-rerate');
    const jsonEl    = document.getElementById('hero-rating-json');

    rater?.addEventListener('commit', (e) => {
      const rating = (e as CustomEvent).detail;
      if (result) result.rating = rating;
      // Populate JSON snippet
      if (jsonEl) {
        const round = (x: number) => +x.toFixed(3);
        jsonEl.textContent = JSON.stringify({
          raw: { v: round(rating.raw.v), a: round(rating.raw.a) },
          composite: rating.composite
            ? { v: round(rating.composite.v), a: round(rating.composite.a), d: round(rating.composite.d) }
            : null,
          labels: rating.labels.map((l: { name: string; level: number; vad?: { v: number; a: number; d: number } }) => ({
            name:  l.name,
            level: l.level,
            vad:   l.vad ? { v: round(l.vad.v), a: round(l.vad.a), d: round(l.vad.d) } : undefined,
          })),
        }, null, 2);
      }
      slot?.classList.add('showing-result');
    });

    // After rater fades out, collapse its height so slot snaps to result size
    raterPane?.addEventListener('transitionend', (e) => {
      if ((e as TransitionEvent).propertyName !== 'opacity') return;
      if (slot?.classList.contains('showing-result') && raterPane) {
        raterPane.style.height   = '0';
        raterPane.style.overflow = 'hidden';
      }
    });

    rerate?.addEventListener('click', () => {
      // Restore rater pane dimensions (still invisible under showing-result)
      if (raterPane) { raterPane.style.height = ''; raterPane.style.overflow = ''; }
      // Let browser process the layout change, then reverse the transition
      requestAnimationFrame(() => {
        slot?.classList.remove('showing-result');
        rater?.reset();
      });
    });

    // ── Compare demo data ──────────────────────────────────────
    const yesterday = [
      createRating({ v: -0.4, a:  0.5, labels: [
        { name: 'overwhelmed', level: 3 },
        { name: 'anxious',     level: 2 },
        { name: 'tired',       level: 1 },
      ]}),
      createRating({ v: -0.5, a:  0.4, labels: [
        { name: 'frustrated',  level: 2 },
        { name: 'tired',       level: 2 },
      ]}),
      createRating({ v: -0.3, a:  0.3, labels: [
        { name: 'overwhelmed', level: 2 },
        { name: 'sad',         level: 1 },
      ]}),
    ];

    const today = [
      createRating({ v:  0.5, a:  0.3, labels: [
        { name: 'calm',     level: 2 },
        { name: 'grateful', level: 1 },
      ]}),
      createRating({ v:  0.7, a:  0.5, labels: [
        { name: 'joy',     level: 3 },
        { name: 'hopeful', level: 2 },
      ]}),
      createRating({ v:  0.6, a:  0.2, labels: [
        { name: 'content',  level: 2 },
        { name: 'grateful', level: 2 },
        { name: 'calm',     level: 1 },
      ]}),
    ];

    const compareEl = document.getElementById('site-compare') as AffectKitCompare | null;
    if (compareEl) {
      compareEl.beforeRating = yesterday;
      compareEl.afterRating  = today;
    }
  </script>

</Base>
