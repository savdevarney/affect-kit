---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Open-source web components for dimensional emotion rating — grounded in affective science.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
  <script>
    // Transparent nav over hero, frosted glass when scrolled
    const nav = document.querySelector('.site-nav') as HTMLElement | null;
    const sentinel = document.querySelector('.hero, .rp-header') as HTMLElement | null;
    if (nav && sentinel) {
      const obs = new IntersectionObserver(
        ([entry]) => nav.classList.toggle('is-scrolled', !entry.isIntersecting),
        { threshold: 0.05 }
      );
      obs.observe(sentinel);
    }

    // ToC: open on wide screens (always visible), collapsed by default on narrow
    // (where it would otherwise eat the screen). Resize-aware.
    const tocDetails = document.querySelector<HTMLDetailsElement>('.rp-toc-details');
    if (tocDetails) {
      const mq = window.matchMedia('(max-width: 860px)');
      const sync = () => {
        if (mq.matches) tocDetails.removeAttribute('open');
        else tocDetails.setAttribute('open', '');
      };
      sync();
      mq.addEventListener('change', sync);
      // Auto-close after picking a link on narrow so the user can read content.
      tocDetails.addEventListener('click', (e) => {
        if (mq.matches && (e.target as HTMLElement).closest('a')) {
          tocDetails.removeAttribute('open');
        }
      });
    }
  </script>
</body>
</html>
