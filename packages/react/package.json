{
  "name": "@affect-kit/react",
  "version": "0.1.0",
  "description": "React wrappers for affect-kit web components — typed props, idiomatic onChange handlers.",
  "license": "MIT",
  "author": "Savannah DeVarney <savannah.devarney@gmail.com>",
  "homepage": "https://affectkit.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/savdevarney/affect-kit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/savdevarney/affect-kit/issues"
  },
  "keywords": [
    "affect-kit",
    "react",
    "web-components",
    "lit",
    "emotion",
    "affect"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "peerDependencies": {
    "react": ">=18",
    "affect-kit": "workspace:*"
  },
  "dependencies": {
    "@lit/react": "^1.0.6"
  },
  "devDependencies": {
    "@affect-kit/tsconfig": "workspace:*",
    "@types/react": "^18.0.0",
    "@types/node": "^22.0.0",
    "react": "^18.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
