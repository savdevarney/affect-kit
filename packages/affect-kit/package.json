{
  "name": "affect-kit",
  "version": "0.0.0",
  "description": "Web components for dimensional emotion rating — built with Lit, grounded in affective science.",
  "license": "MIT",
  "author": "Savannah DeVarney <savannah.devarney@gmail.com>",
  "homepage": "https://affectkit.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/savdevarney/affect-kit.git",
    "directory": "packages/affect-kit"
  },
  "bugs": {
    "url": "https://github.com/savdevarney/affect-kit/issues"
  },
  "keywords": [
    "web-components",
    "lit",
    "emotion",
    "affect",
    "valence",
    "arousal",
    "VAD",
    "PAD",
    "affective-computing",
    "self-rating",
    "wellbeing"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/rater.js",
    "./dist/result.js",
    "./dist/face.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rater": {
      "types": "./dist/rater.d.ts",
      "import": "./dist/rater.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js"
    },
    "./face": {
      "types": "./dist/face.d.ts",
      "import": "./dist/face.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "lint": "eslint src test --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage test-results playwright-report"
  },
  "peerDependencies": {
    "lit": "^3.2.0"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@affect-kit/tsconfig": "workspace:*",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@web/test-runner": "^0.20.0",
    "@web/test-runner-playwright": "^0.11.0",
    "@arethetypeswrong/cli": "^0.17.0",
    "publint": "^0.3.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
